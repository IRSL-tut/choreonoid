msgid ""
"PiecewiseRigidContinuousTrack \"{0}\" (link \"{1}\"): Adjusted num_shoes from {2} to {3} for "
"phase alignment between wheels and linear segments.{4}"
msgstr ""
"PiecewiseRigidContinuousTrack \"{0}\" (リンク \"{1}\"): 車輪と直線区間の位相整合のため、"
"num_shoesを{2}から{3}に調整しました。{4}"

msgid ""
"PiecewiseRigidContinuousTrack \"{0}\" (link \"{1}\"): num_shoes={2} is not phase-aligned with "
"wheel distance {3:.4f}. Suggested wheel distance: {4}.{5}"
msgstr ""
"PiecewiseRigidContinuousTrack \"{0}\" (リンク \"{1}\"): num_shoes={2}は車輪間距離{3:.4f}と"
"位相が合っていません。推奨車輪間距離: {4}。{5}"

msgid ""
"The \"PxContinuousTrack\" device type is deprecated. Use "
"\"PiecewiseRigidContinuousTrack\" instead."
msgstr ""
"\"PxContinuousTrack\"デバイス型は非推奨です。代わりに"
"\"PiecewiseRigidContinuousTrack\"を使用してください。"
