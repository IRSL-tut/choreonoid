msgstr "浮動小数点数の配列を解析できません．"

msgid "An array of integers cannot be parsed."
msgstr "整数の配列を解析できません．"

msgid "The XML data cannot be parsed. {0}"
msgstr "XMLデータを解析できません．{0}"

msgid "The file does not have the COLLADA root element."
msgstr "ファイルにCOLLADAのルート要素がありません．"

msgid "COLLADA file \"{0}\" cannot be loaded: {1}"
msgstr "COLLADAファイル \"{0}\" を読み込めません： {1}"

msgid "Warning: External document reference \"{0}\" is not supported."
msgstr "警告： 外部ドキュメント参照 \"{0}\" はサポートされていません．"

msgid "Warning: The element referenced by \"{0}\" is not found."
msgstr "警告： \"{0}\" が参照する要素がみつかりません．"

msgid "Warning: The up axis \"{0}\" is ignored and the coordinates are interpreted as Z-up."
msgstr "警告： アップ軸 \"{0}\" は無視され，座標はZ-upとして解釈されます．"

msgid "The file does not have any visual scenes."
msgstr "ファイルにビジュアルシーンがありません．"

msgid "A matrix element does not have 16 values."
msgstr "matrix要素が16個の値を持っていません．"

msgid "Warning: The \"{0}\" transformation elements are not supported and ignored."
msgstr "警告： \"{0}\" 変換要素はサポートされておらず無視されます．"

msgid "Warning: Skinning and morphing are not supported and the base geometries are used."
msgstr "警告： スキニングおよびモーフィングはサポートされておらず，基本ジオメトリが使用されます．"

msgid "Warning: Geometries other than the mesh type (convex_mesh, spline, brep) are not supported and skipped."
msgstr "警告： mesh型以外のジオメトリ（convex_mesh, spline, brep）はサポートされておらずスキップされます．"

msgid "Warning: The \"{0}\" primitives are not supported and skipped."
msgstr "警告： \"{0}\" プリミティブはサポートされておらずスキップされます．"

msgid "Warning: Only the first texture coordinate set is supported."
msgstr "警告： 最初のテクスチャ座標セットのみサポートされています．"

msgid "Warning: A primitive without the vertex positions is skipped."
msgstr "警告： 頂点位置を持たないプリミティブはスキップされます．"

msgid "Warning: The source \"{0}\" cannot be read as 3D vectors."
msgstr "警告： ソース \"{0}\" を3次元ベクトルとして読み込めません．"

msgid "Warning: The source \"{0}\" cannot be read as 2D vectors."
msgstr "警告： ソース \"{0}\" を2次元ベクトルとして読み込めません．"

msgid "Warning: Polygons with holes are not supported and the holes are ignored."
msgstr "警告： 穴のあるポリゴンはサポートされておらず，穴は無視されます．"

msgid "The number of the indices of a primitive does not match its vertex counts."
msgstr "プリミティブのインデックス数が頂点カウントと一致しません．"

msgid "A primitive has an out-of-range normal index."
msgstr "プリミティブが範囲外の法線インデックスを有しています．"

msgid "A primitive has an out-of-range texture coordinate index."
msgstr "プリミティブが範囲外のテクスチャ座標インデックスを有しています．"

msgid "A primitive has an out-of-range color index."
msgstr "プリミティブが範囲外の色インデックスを有しています．"

msgid "Warning: Material symbol \"{0}\" is not found in the material bindings."
msgstr "警告： マテリアルシンボル \"{0}\" がマテリアルバインディングにみつかりません．"

msgid "Warning: Material \"{0}\" is not found."
msgstr "警告： マテリアル \"{0}\" がみつかりません．"

msgid "Warning: Effects without the common profile are not supported and the default material is used."
msgstr "警告： common profileを持たないエフェクトはサポートされておらず，デフォルトマテリアルが使用されます．"

msgid "Warning: Image \"{0}\" is not found."
msgstr "警告： 画像 \"{0}\" がみつかりません．"

msgid "Warning: Image \"{0}\" does not have a file reference and is skipped."
msgstr "警告： 画像 \"{0}\" にファイル参照がなくスキップされます．"
