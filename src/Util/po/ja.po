msgid ""
"\"{}\" does not have elements in multiple of twelve (each 3 for position vectors, 9 for attitde "
"matrices)"
msgstr "\"{}\" には12の倍数の要素がありません．（3要素が位置ベクトル，9要素が姿勢行列）"

