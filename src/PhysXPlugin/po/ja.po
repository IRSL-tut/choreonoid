msgid ""
"{0} has a non-axis-aligned scaling which is not supported in the PhysX plugin. The mesh is "
"skipped."
msgstr ""
"{0}は軸に沿わないスケーリングを持っており、PhysXプラグインではサポートされていません。このメッシュ"
"はスキップされます。"

msgid ""
"vertices: {0}, unique vertices: {1}, duplicate vertices: {2}, triangles: {3}, invalid triangles: "
"{4}, degenerate triangles: {5}."
msgstr ""
"頂点数: {0}, ユニーク頂点数: {1}, 重複頂点数: {2}, 三角形数: {3}, 不正な三角形数: {4}, 縮退三角形"
"数: {5}."

msgid "Mesh cleaning modified {0}: vertices {1} -> {2}, triangles {3} -> {4}."
msgstr "メッシュクリーニングにより{0}を修正しました: 頂点数 {1} -> {2}, 三角形数 {3} -> {4}."

msgid "{0} has mesh data problems for PhysX triangle mesh cooking. {1}"
msgstr "{0}のメッシュデータに問題があります。PhysX三角メッシュ作成に使用できません。{1}"

msgid "Mesh cleaning is disabled. The PhysX triangle mesh for {0} is not created."
msgstr "メッシュクリーニングが無効です。{0}のPhysX三角メッシュは作成されません。"

msgid "Mesh cleaning failed for {0}. The PhysX triangle mesh is not created. Cooking result: {1}."
msgstr ""
"メッシュクリーニングに失敗しました。{0}のPhysX三角メッシュは作成されません。cooking結果: {1}."

msgid "The PhysX triangle mesh for {0} is not created. Cooking result: {1}."
msgstr "{0}のPhysX三角メッシュは作成されません。cooking結果: {1}."

msgid "{0} has no valid vertices for creating a convex mesh."
msgstr "{0}には凸メッシュを作成するための有効な頂点がありません。"

msgid "{0} cannot be converted to a convex mesh."
msgstr "{0}を凸メッシュに変換できません。"

msgid ""
"PxContinuousTrack \"{0}\" (link \"{1}\"): Adjusted num_shoes from {2} to {3} for phase alignment "
"between wheels and linear segments.{4}"
msgstr ""
"PxContinuousTrack \"{0}\" (リンク \"{1}\"): 車輪とリニアセグメント間の位相整合のため、num_shoes"
"を{2}から{3}に調整しました。{4}"

msgid ""
"PxContinuousTrack \"{0}\" (link \"{1}\"): num_shoes={2} is not phase-aligned with wheel distance "
"{3:.4f}. Suggested wheel distance: {4}.{5}"
msgstr ""
"PxContinuousTrack \"{0}\" (リンク \"{1}\"): num_shoes={2}は車輪間距離{3:.4f}と位相が合っていま"
"せん。推奨車輪間距離: {4}。{5}"
